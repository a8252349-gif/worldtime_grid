{
  "name": "time-zone-meeting-planner",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-public-files.mjs",
    "build": "next build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "check:content": "node scripts/check-content-quality.mjs",
    "check:length": "node scripts/check-guide-length.mjs",
    "check:duplicates": "node scripts/check-duplicate-content.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:hreflang": "node scripts/check-hreflang.mjs",
    "check:sitemap": "node scripts/check-sitemap.mjs",
    "check:timezones": "node scripts/check-time-zone-results.mjs",
    "audit": "npm run check:registry && npm run check:content && npm run check:length && npm run check:duplicates && npm run check:links && npm run check:hreflang && npm run check:sitemap && npm run check:timezones && npm run check:language && npm run check:public-copy && npm run check:metadata && npm run check:orphans && npm run check:ads",
    "check:registry": "node scripts/check-package-registry.mjs",
    "check:language": "node scripts/check-language-purity.mjs",
    "check:public-copy": "node scripts/check-public-copy.mjs",
    "check:metadata": "node scripts/check-metadata-uniqueness.mjs",
    "check:orphans": "node scripts/check-orphan-pages.mjs",
    "check:ads": "node scripts/check-empty-ad-slots.mjs"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.6.2",
    "luxon": "^3.7.2",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.29.0",
    "eslint-config-next": "16.2.9",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "serve": "14.2.6"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
